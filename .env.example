# Open Hoops — Environment Variables
#
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your values
#   docker compose -f infra/docker-compose.yml up -d

# ─────────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────────
POSTGRES_USER=openhoops
# REQUIRED: Set a strong password
POSTGRES_PASSWORD=changeme_use_a_strong_password
POSTGRES_DB=openhoops

# ─────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────
# Redis connection URL used by API and all worker services
REDIS_URL=redis://redis:6379/0

# ─────────────────────────────────────────────
# MinIO Object Storage
# ─────────────────────────────────────────────
# REQUIRED: Set strong credentials (min 8 chars each for MinIO)
MINIO_ROOT_USER=openhoops-minio
MINIO_ROOT_PASSWORD=changeme_minio_password
# Internal Docker network endpoint (used by backend services)
MINIO_ENDPOINT=minio:9000
MINIO_SECURE=false
# External endpoint (used by the API to build signed URLs for the browser)
MINIO_EXTERNAL_ENDPOINT=http://localhost:9000

# ─────────────────────────────────────────────
# Ollama / LLM
# ─────────────────────────────────────────────
OLLAMA_HOST=http://ollama:11434
# Model to use for coaching reports. The model will be pulled automatically on first use.
# Options: llama3.1:8b, llama3.1:70b-q4, mistral:7b, qwen2:7b
LLM_MODEL=llama3.1:8b
# Max seconds to wait for report generation before timeout
LLM_REPORT_TIMEOUT_SECONDS=120

# ─────────────────────────────────────────────
# API
# ─────────────────────────────────────────────
# Comma-separated list of allowed CORS origins. Never use * in production.
ALLOWED_ORIGINS=http://localhost:3000
# Max video upload size in bytes (default: 4 GB)
MAX_UPLOAD_SIZE_BYTES=4294967296

# ─────────────────────────────────────────────
# Signed URL Expiry (seconds)
# ─────────────────────────────────────────────
# Calibration frame images and debug frames
SIGNED_URL_EXPIRY_FRAME_MINUTES=30
# Full telemetry JSON downloads (large files)
SIGNED_URL_EXPIRY_TELEMETRY_HOURS=24
# Analytics summaries, reports, heatmaps
SIGNED_URL_EXPIRY_ARTIFACT_HOURS=1

# ─────────────────────────────────────────────
# CV Worker
# ─────────────────────────────────────────────
# YOLO model file. yolov8n.pt = nano (CPU fast). yolov8m.pt = medium (GPU recommended).
YOLO_MODEL=yolov8n.pt
# Detection confidence threshold (0.0 – 1.0)
YOLO_CONFIDENCE_THRESHOLD=0.4
# Process every Nth frame (3 = 10fps effective at 30fps input)
FRAME_SAMPLE_RATE=3
# Number of concurrent CV jobs (keep at 1 for CPU)
CV_WORKER_CONCURRENCY=1

# ─────────────────────────────────────────────
# Frontend
# ─────────────────────────────────────────────
# API base URL used by the Next.js frontend (browser-accessible)
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─────────────────────────────────────────────
# AMD ROCm (GPU override — docker-compose.gpu.yml only)
# ─────────────────────────────────────────────
# Required for some RDNA3 cards (RX 7000 / RX 9000 series) until full upstream ROCm support.
# Set to "11.0.0" for RDNA3 gfx1100. Leave empty to let ROCm auto-detect.
HSA_OVERRIDE_GFX_VERSION=
